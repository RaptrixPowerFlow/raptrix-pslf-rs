# =====================================================================
# CEII / PROPRIETARY DATA — NEVER COMMIT
# =====================================================================
# PSLF test cases (EPC + DYD) may contain CEII or proprietary grid data.
# These files live only on developer machines. They must never reach GitHub.
tests/networks/
tests/networks/**

# =====================================================================
# Test data may contain confidential or licensed power-system cases.
# Golden output RPF files are regenerated by `cargo test` — no need to track.
# =====================================================================
tests/data/external/
tests/golden/*.rpf

